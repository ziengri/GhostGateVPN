# App
APP_NAME=GhostGateVPN
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
APP_PUBLIC_URL=https://api.ghostgate.pro
APP_SECRET_KEY=change-me-super-secret
CORS_ORIGINS=http://localhost:80,http://127.0.0.1:80,http://host.docker.internal:80,http://ghostgate.pro,https://ghostgate.pro,https://www.ghostgate.pro

# PostgreSQL
POSTGRES_DB=vpn_service
POSTGRES_USER=vpn_user
POSTGRES_PASSWORD=vpn_password
DATABASE_URL=postgresql+asyncpg://vpn_user:vpn_password@postgres:5432/vpn_service

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# AWG Server
AWG_API_BASE_URL=http://host.docker.internal:7777
AWG_API_TOKEN=change-me-awg-token
AWG_TIMEOUT_SECONDS=10

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=VPN Service
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_ENABLED=true

# Workers
SCHEDULER_ENABLED=true
